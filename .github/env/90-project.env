# ================================================================================================
# 🏗️ PROJECT CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for go-meta-extractor
# Load Order: 90 (loaded after all defaults, overrides any previous values)
#
# This file contains project-specific configuration that overrides the defaults
# set in earlier env files (00-core, 10-*, 20-*). Only include values that
# differ from the defaults.
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

GO_PRIMARY_VERSION=1.25.x
GO_SECONDARY_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x
MAGE_X_GO_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE PROVIDER CONFIGURATION
# ================================================================================================

# Use Codecov as the coverage provider (overrides default: internal)
GO_COVERAGE_PROVIDER=codecov

# Require Codecov token for uploads (overrides default: false)
CODECOV_TOKEN_REQUIRED=true

# ================================================================================================
# 🚫 COVERAGE EXCLUSIONS
# ================================================================================================

# Coverage path exclusions (aligned with codecov.yml ignore paths)
GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,docs/,example/,examples/,mocks/,test/,testing/,testdata/,vendor/

# ================================================================================================
# 🛡️ CVE EXCLUSIONS
# ================================================================================================

# golang.org/x/crypto vulnerabilities flagged by nancy
NANCY_EXCLUDES=CVE-2026-39827,CVE-2026-39828,CVE-2026-39829,CVE-2026-39830,CVE-2026-39831,CVE-2026-39832,CVE-2026-39833,CVE-2026-39834,CVE-2026-42508,CVE-2026-46595,CVE-2026-46597,CVE-2026-46598
MAGE_X_CVE_EXCLUDES=CVE-2026-39827,CVE-2026-39828,CVE-2026-39829,CVE-2026-39830,CVE-2026-39831,CVE-2026-39832,CVE-2026-39833,CVE-2026-39834,CVE-2026-42508,CVE-2026-46595,CVE-2026-46597,CVE-2026-46598
